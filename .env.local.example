# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_EMAILS=admin@example.com
ADMIN_SESSION_SECRET=replace-with-a-dedicated-admin-session-secret
PUBLIC_ORDER_ACCESS_SECRET=replace-with-a-dedicated-public-order-secret
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
RATE_LIMIT_PREFIX=tendy

# Database (Prisma)
DATABASE_URL=postgresql://postgres:password@host:6543/postgres
DIRECT_URL=postgresql://postgres:password@host:5432/postgres

# Email (Resend)
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# Bank Info (shown to users)
NEXT_PUBLIC_BANK_NAME=銀行名稱
NEXT_PUBLIC_BANK_ACCOUNT=000-000000000000
NEXT_PUBLIC_BANK_HOLDER=帳戶持有人

# Site
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
