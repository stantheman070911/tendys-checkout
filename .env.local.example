# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ADMIN_EMAILS=admin@example.com
# Generate locally with: openssl rand -base64 32
# Used to sign admin session cookies. Must be different from PUBLIC_ORDER_ACCESS_SECRET.
ADMIN_SESSION_SECRET=your-admin-session-secret
PUBLIC_ORDER_ACCESS_SECRET=your-public-order-access-secret

UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
# Get from the same Upstash Redis database REST API settings page as the bearer token.
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
# Choose a unique namespace for this environment, e.g. tendy-staging or tendy-prod.
RATE_LIMIT_PREFIX=tendy

# Database (Prisma)
DATABASE_URL=postgresql://postgres:password@db.example.com:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.example.com:5432/postgres

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=orders@example.com

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# Bank Info (shown to users)
NEXT_PUBLIC_BANK_NAME=Example Bank
NEXT_PUBLIC_BANK_ACCOUNT=000-000000000000
NEXT_PUBLIC_BANK_HOLDER=Example Holder

# Site
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Staging Smoke
# Use the staging deployment origin only, e.g. https://your-staging-app.vercel.app
STAGING_BASE_URL=
# Get a real Supabase access token by logging into the staging admin UI with an allowed ADMIN_EMAILS account.
# In browser DevTools, inspect POST /api/admin/session and copy the Authorization bearer token value without the "Bearer " prefix.
STAGING_ADMIN_BEARER_TOKEN=
# If the preview deployment uses Vercel Deployment Protection, provide a bypass secret here.
# The scripts accept either STAGING_VERCEL_BYPASS_SECRET or VERCEL_AUTOMATION_BYPASS_SECRET.
STAGING_VERCEL_BYPASS_SECRET=
# Optional override for smoke test purchaser identity.
STAGING_SMOKE_PURCHASER_NAME=
# Optional override for smoke test phone number.
STAGING_SMOKE_PHONE=
# Optional override for smoke test email.
STAGING_SMOKE_EMAIL=
# Optional override for smoke test delivery address.
STAGING_SMOKE_ADDRESS=
