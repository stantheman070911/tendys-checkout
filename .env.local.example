# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Prisma)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Email (Resend)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# LINE Notify
LINE_NOTIFY_TOKEN=your-line-notify-token

# Bank info (shown to users)
NEXT_PUBLIC_BANK_NAME=國泰世華銀行
NEXT_PUBLIC_BANK_ACCOUNT=012-345678901234
NEXT_PUBLIC_BANK_HOLDER=王小明

# Site
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
