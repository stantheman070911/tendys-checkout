enum OrderStatus {
  PENDING   // Order placed, waiting for user to paste code into LINE
  LINKED    // LINE ID linked — ready to receive notifications
  SHIPPED   // Shipped — notification sent
  DELIVERED // Delivered
}

model Order {
  id           String      @id @default(cuid())
  name         String      // Buyer name
  phone        String?     // Optional contact phone
  items        Json        // Flexible: [{ name, qty, price }, ...]
  note         String?     // Optional order note
  status       OrderStatus @default(PENDING)
  line_user_id String?     // Null until user pastes code into LINE bot
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  code         OrderCode?
}

model OrderCode {
  id         String   @id @default(cuid())
  code       String   @unique  // 8-char alphanumeric, e.g. "A3KX9P2M"
  order_id   String   @unique  // One code per order
  order      Order    @relation(fields: [order_id], references: [id])
  used       Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())
}
